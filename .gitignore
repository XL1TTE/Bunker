## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of the Visual Studio and .NET GitIgnore templates.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
log/
logs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image build caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on VFAT chunks
$RECYCLE.BIN/

# VS Code files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Aspire
.aspire/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Backup & checkpoint files
*.bak
*.cache
*.out
*.err

# Paket dependency manager
.paket/
paket-files/

# FAKE - F# Make
.fake/

# CodeRush personal settings
.cr/

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.pyc

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
.dockerignore

# End of standard .NET GitIgnore
